{
  "name": "uxreview",
  "version": "0.1.0",
  "description": "CLI tool that orchestrates Claude Code instances to autonomously review web application UX via Playwright MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "uxreview": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ux", "review", "claude", "playwright", "cli"],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
